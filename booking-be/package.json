    "@babel/node": "^7.12.10",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "jest": "^29.7.0",
    "nodemon": "^2.0.7",
    "sequelize-cli": "^6.6.1"
  }
