{
  "name": "node",
  "version": "1.0.0",
  "description": "backend nodejs",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "start": "nodemon --exec ./node_modules/.bin/babel-node src/server.js",
    "build-src": "babel src -d build --copy-files",
    "build": "node build/server.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/src/__tests__/**/*.test.js"],
    "transform": { "^.+\\.js$": "babel-jest" }
  },
  "author": "QuocDuong",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "ejs": "^3.1.5",
    "exact": "^0.8.0",
    "express": "^4.17.1",
    "express-session": "^1.19.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mysql2": "^3.6.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.15.2",
    "sequelize": "^6.33.0",
    "socket.io": "^4.7.5",
    "uuid": "^8.3.2",
    "winston": "^3.19.0"
  },
  "repository": {
