# ============================================
# Backend env template — copy to booking-be/.env
# ============================================

# --- Database (MySQL) ---
DB_USERNAME=root
DB_PASSWORD=123456
DB_DATABASE_NAME=quocduong
DB_HOST=127.0.0.1
DB_PORT=3308
DB_DIALECT=mysql

# --- Server ---
PORT=8080
NODE_ENV=development
# Frontend origin — used for CORS + email links + Google OAuth redirect
URL_REACT=http://localhost:3000
# Public site URL for email footer links
SITE_URL=http://localhost:3000

# --- Auth / Security ---
# Change this in production. Must be a long random string.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# --- Google OAuth (optional, social login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Gmail App Password) ---
# Create Gmail App Password at https://myaccount.google.com/apppasswords
EMAIL_APP=your-sender@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_BRAND_NAME=BookingCare
EMAIL_BRAND_COLOR=#0d6efd

# --- VNPay (sandbox keys) ---
# Get from https://sandbox.vnpayment.vn/devreg
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Leave blank to default to URL_REACT/payment/vnpay-return
VNP_RETURN_URL=

# --- Doctor schedule ---
# Max patients per time slot
MAX_NUMBER_SCHEDULE=10

# --- Reminder cron ---
# Cron expression for appointment reminder job. Default: every hour on the hour
REMINDER_CRON=0 * * * *
CRON_TZ=Asia/Ho_Chi_Minh
